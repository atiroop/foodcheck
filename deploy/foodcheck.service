[Unit]
Description=FoodCheck Web App
After=network.target

[Service]
Type=simple
User=jocky
WorkingDirectory=/home/jocky/web/foodcheck.jocky.website/app/web
ExecStart=/home/jocky/web/foodcheck.jocky.website/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8010 --workers 1
Restart=always
RestartSec=5
Environment=PYTHONPATH=/home/jocky/web/foodcheck.jocky.website/app

[Install]
WantedBy=multi-user.target
